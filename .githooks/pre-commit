#!/usr/bin/env bash
# Enforce rustfmt + clippy on staged backend Rust changes, matching the CI
# "Rust" job (cargo fmt --check + clippy -D warnings). Only runs when Rust
# files or a backend manifest are staged. Bypass with `git commit --no-verify`.
#
# Portable to macOS's stock bash 3.2 — no `mapfile` / associative arrays.
set -euo pipefail

root="$(git rev-parse --show-toplevel)"

staged="$(git diff --cached --name-only --diff-filter=ACMR)"
rust_files="$(printf '%s\n' "$staged" | grep -E '^src/backend/.*\.rs$' || true)"
manifests="$(printf '%s\n' "$staged" | grep -E '^src/backend/(.+/)?Cargo\.(toml|lock)$' || true)"

if [ -z "$rust_files" ] && [ -z "$manifests" ]; then
    exit 0
fi

cd "$root/src/backend"

echo "[pre-commit] cargo fmt --check"
cargo fmt --all --check

# Clippy, scoped to the crates that own the changed files (fast on a warm
# target dir); fall back to the whole workspace when only a manifest changed.
pkgs=""
if [ -n "$rust_files" ]; then
    while IFS= read -r f; do
        [ -n "$f" ] || continue
        dir="$root/$(dirname "$f")"
        while [ "$dir" != "$root/src/backend" ] && [ "$dir" != "/" ]; do
            if [ -f "$dir/Cargo.toml" ] && grep -q '^\[package\]' "$dir/Cargo.toml"; then
                name="$(sed -n 's/^name *= *"\(.*\)"/\1/p' "$dir/Cargo.toml" | head -1)"
                case " $pkgs " in
                    *" $name "*) : ;;
                    *) [ -n "$name" ] && pkgs="$pkgs $name" ;;
                esac
                break
            fi
            dir="$(dirname "$dir")"
        done
    done <<EOF
$rust_files
EOF
fi

if [ -z "$pkgs" ]; then
    echo "[pre-commit] cargo clippy --workspace --all-targets"
    cargo clippy --workspace --all-targets -- -D warnings
else
    for p in $pkgs; do
        echo "[pre-commit] cargo clippy -p $p --all-targets"
        cargo clippy -p "$p" --all-targets -- -D warnings
    done
fi
