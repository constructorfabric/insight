# E2E test data tier — committed, test-specific docker compose env file.
#
# Passed to `docker compose --env-file` by ../e2e.sh and e2e_lib/compose.py so
# the e2e stack does NOT depend on a developer's personal .env.compose. Values
# match the repo-root docker-compose.yml defaults (.env.compose.example), so the
# runner attaches cleanly to a default `./dev-compose.sh up` AND to a fresh CI
# bring-up alike.
#
# If your dev stack uses CUSTOM credentials/ports, either mirror them here or
# point the harness at your own file:
#   E2E_ENV_FILE=../../../../.env.compose ./e2e.sh test

# Always use the LOCAL data tier — e2e never targets external DBs.
MARIADB_EXTERNAL=false
CLICKHOUSE_EXTERNAL=false

# Credentials (match docker-compose.yml service defaults).
CLICKHOUSE_USER=insight
CLICKHOUSE_PASSWORD=insight-local
MARIADB_USER=insight
MARIADB_PASSWORD=insight-local
MARIADB_ROOT_PASSWORD=root-local

# Published host ports — host-mode pytest connects here; harmless in docker mode.
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
MARIADB_PORT=3306

# In-network container ports — the runner override reads these.
CLICKHOUSE_INTERNAL_HTTP_PORT=8123
MARIADB_INTERNAL_PORT=3306
