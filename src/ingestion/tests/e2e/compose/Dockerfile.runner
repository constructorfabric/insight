# Dev/CI runner for the Bronze-to-API E2E test framework.
#
# Bakes in:
#   - Python 3.12 + lib deps (pytest, clickhouse-connect, pandas, dbt-clickhouse, …)
#   - the analytics binary and each connector's enrich binary, each COMPILED
#     FROM ITS OWN Dockerfile and pulled in via `COPY --from=<ctx>` (the contexts
#     are wired in docker-compose.runner.yml `runner.build.additional_contexts`).
#
# The rig compiles nothing itself — there is NO Rust toolchain here. The repo is
# bind-mounted at /workspace at runtime.
#
# This image is the SAME one used locally and in CI — see ../e2e.sh and
# .github/workflows/e2e-bronze-to-api.yml.

FROM python:3.12-slim-bookworm

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# ── System tooling ──────────────────────────────────────────────────────
# ca-certificates for HTTPS (pip, clickhouse-connect); git for any dbt tooling
# that shells out. No compilers/toolchains: all binaries are baked in pre-built.
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        git \
    && rm -rf /var/lib/apt/lists/*

# ── ASP.NET runtime (for the .NET identity service under test) ──────────
# The identity contract suite (identity/, #1753) spawns the published
# Insight.Identity.Api in-process, exactly like the analytics binary — a
# framework-dependent .NET app needs the aspnetcore runtime. TEMPORARY: goes
# away with the .NET service once the Rust identity-resolution cutover lands
# (the Rust binary will bake in like analytics does).
# Installed via the official dotnet-install script — Microsoft's Debian apt
# feed does not carry the 9.0 runtime packages. libicu is the runtime's only
# system dependency the slim base lacks. The script is fetched to a file over
# TLS from dot.net (Microsoft's canonical host; no stable published checksum
# exists to verify against). `--channel 9.0` deliberately patch-floats: the
# channel is pinned to the identity service's TargetFramework (net9.0), and
# this is a disposable test-runner image, not a shipped artifact — a stale
# pinned patch would only delay security fixes here. The runtime (and this
# whole block) leaves with the frozen .NET service at the Rust cutover.
RUN apt-get update && apt-get install -y --no-install-recommends curl libicu72 \
    && curl -sSL https://dot.net/v1/dotnet-install.sh -o /tmp/dotnet-install.sh \
    && bash /tmp/dotnet-install.sh --channel 9.0 --runtime aspnetcore --install-dir /usr/share/dotnet \
    && rm /tmp/dotnet-install.sh \
    && ln -s /usr/share/dotnet/dotnet /usr/local/bin/dotnet \
    && apt-get purge -y curl && apt-get autoremove -y \
    && rm -rf /var/lib/apt/lists/*

# ── Python deps (cached layer: only invalidates when pyproject changes) ─
# Build context is the repo root, so we copy from src/ingestion/tests/e2e/
# explicitly. Only pyproject is needed at build time — code lives at
# /workspace via bind mount.
WORKDIR /workspace/src/ingestion/tests/e2e
COPY src/ingestion/tests/e2e/pyproject.toml ./pyproject.toml
RUN mkdir -p lib && touch lib/__init__.py \
    && pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -e . \
    && rm -rf lib

# ── Pre-built binaries (baked from each component's OWN Dockerfile) ───────
# Named build contexts come from docker-compose.runner.yml build-only services;
# the rig RUNS these (analytics as a spawned service; enrich between the
# staging and silver dbt builds) but never compiles them. One COPY per binary
# (matches the `additional_contexts` entries).
COPY --from=analytics /app/analytics /usr/local/bin/analytics
COPY --from=jira-enrich /usr/local/bin/jira-enrich /usr/local/bin/jira-enrich
# The .NET identity published app (framework-dependent; spawned via `dotnet`).
COPY --from=identity /app /opt/insight-identity

# ── Defaults ────────────────────────────────────────────────────────────
ENV E2E_RUN_MODE=docker
ENV PYTHONPATH=/workspace/src/ingestion/tests/e2e

CMD ["pytest", "--tb=short"]
