apiVersion: v1
kind: Secret
metadata:
  name: insight-active-directory-main
  labels:
    app.kubernetes.io/part-of: insight
  annotations:
    insight.cyberfabric.com/connector: active-directory
    insight.cyberfabric.com/source-id: active-directory-main
type: Opaque
stringData:
  ad_server_host: "CHANGE_ME"     # DC hostname/IP, no scheme/port (e.g. "dc1.corp.example.com")
  ad_bind_dn: "CHANGE_ME"         # service-account DN or UPN (e.g. "svc-insight@corp.example.com")
  ad_bind_password: "CHANGE_ME"   # service-account password (sensitive)
  ad_search_base: "CHANGE_ME"     # base DN (e.g. "DC=corp,DC=example,DC=com")
  # Optional overrides:
  # ad_port: "636"                # default 636 (LDAPS) / 389 (plaintext)
  # ad_use_ssl: "true"            # default true
  # ad_user_filter: "(&(objectClass=user)(objectCategory=person)(!(sAMAccountName=krbtgt)))"
  # ad_page_size: "500"
