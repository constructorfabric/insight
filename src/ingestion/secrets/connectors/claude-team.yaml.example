apiVersion: v1
kind: Secret
metadata:
  name: insight-claude-team-main
  labels:
    app.kubernetes.io/part-of: insight
  annotations:
    insight.cyberfabric.com/connector: claude-team
    insight.cyberfabric.com/source-id: claude-team-main
type: Opaque
stringData:
  # Required — UUID of the claude.ai organisation we collect data for.
  # Find it via DevTools console on claude.ai:
  #   fetch('/api/organizations').then(r=>r.json()).then(console.table)
  # Pick the row that matches your org name, copy the `uuid` column.
  claude_org_id: "CHANGE_ME"

  # Required — base URL of the customer-deployed claude-team-proxy.
  # The proxy lives in a separate repo and is hosted by the customer:
  #   https://gitlab.constr.dev/insight/secure-enclave → proxies/claude_team/
  # Insight calls this URL over the network. No default — the operator
  # MUST set the actual customer-exposed endpoint here.
  proxy_url: "https://claude-team-proxy.customer.example.com"

  # Required — bearer token Insight sends to the proxy on every request:
  #   Authorization: Bearer <proxy_auth_token>
  # Must match PROXY_AUTH_TOKEN on the proxy container. Generated by the
  # customer (e.g. `openssl rand -hex 32`) and shared out-of-band.
  proxy_auth_token: "CHANGE_ME"

  # NOTE: there is NO claude.ai sessionKey in this Secret. The session
  # cookie lives only inside the customer's proxy container and is
  # installed via the proxy's POST /admin/session-key endpoint. When the
  # cookie expires (~30-90 days), the customer rotates it on the proxy
  # without any change on the Insight side.

  # NOTE: insight_source_id is NOT a stringData field. It is injected
  # from the insight.cyberfabric.com/source-id annotation above.
